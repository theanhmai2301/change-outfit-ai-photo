    <!-- Errors -->
    <string name="err_network">இணைய இணைப்பு இல்லை. Wi-Fi/டேட்டாவைச் சரிபார்த்து மீண்டும் முயற்சிக்கவும்.</string>
    <string name="err_timeout">நெட்வொர்க் மெதுவாக உள்ளதால் அதிக நேரம் எடுத்தது. மீண்டும் முயற்சிக்கவும்.</string>
    <string name="err_service_unavailable">ட்ரை-ஆன் சிறிது இடைவேளை எடுக்கிறது. சில நிமிடங்களில் மீண்டும் முயற்சிக்கவும்.</string>
    <string name="err_server_busy">AI சர்வர் பிஸியாக உள்ளது. சிறிது நேரத்தில் மீண்டும் முயற்சிக்கவும்.</string>
    <string name="err_rate_limited">நீங்கள் மிக வேகமாகச் செல்கிறீர்கள். சிறிது நேரம் காத்திருந்து மீண்டும் முயற்சிக்கவும்.</string>
    <string name="err_too_large">படம் மிகப் பெரியது. சிறிய ஒன்றைத் தேர்ந்தெடுத்து மீண்டும் முயற்சிக்கவும்.</string>

    <string name="err_garment_invalid">உடைப் புகைப்படம் தவறானது. பொருளை நேராகக் காட்டும் தெளிவான JPG அல்லது PNG-ஐப் பயன்படுத்தவும்.</string>
    <string name="err_garment_unrecognized">AI-ஆல் உடையை அடையாளம் காண முடியவில்லை. எளிய பின்னணியில் ஒரே ஒரு பொருளை (மேல் உடை, கீழ் உடை, ஆடை…) காட்டும் தெளிவான புகைப்படத்தைப் பயன்படுத்தவும் — காட்சிகள், இருண்ட அல்லது நெரிசலான புகைப்படங்களைத் தவிர்க்கவும்.</string>
    <string name="err_image_missing">படம் இல்லை. உங்கள் புகைப்படத்தையும் உடைப் புகைப்படத்தையும் மீண்டும் தேர்ந்தெடுத்து முயற்சிக்கவும்.</string>
    <string name="err_bad_request">இந்தப் புகைப்படம் ட்ரை-ஆனுக்கு ஏற்றதல்ல. தெளிவான முழு உடல் புகைப்படத்தையும் தெளிவான உடைப் புகைப்படத்தையும் பயன்படுத்தவும்.</string>

    <string name="err_read_image">தேர்ந்தெடுத்த புகைப்படத்தைப் படிக்க முடியவில்லை. மற்றொன்றை முயற்சிக்கவும்.</string>
    <string name="err_read_garment">உடைப் புகைப்படத்தைப் படிக்க முடியவில்லை. மற்றொன்றைத் தேர்ந்தெடுக்கவும்.</string>
    <string name="err_capture">புகைப்படத்தை எடுக்க முடியவில்லை. மீண்டும் முயற்சிக்கவும்.</string>

    <string name="err_generic">ட்ரை-ஆனில் ஏதோ தவறு ஏற்பட்டது. மீண்டும் முயற்சிக்கவும்.</string>

