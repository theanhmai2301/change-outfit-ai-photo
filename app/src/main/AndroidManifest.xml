<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="com.google.android.gms.permission.AD_ID" />

    <uses-feature
        android:name="android.hardware.camera.any"
        android:required="false" />

    <application
        android:name=".StyleSwapApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/ai_photo_change_outfit"
        android:label="@string/app_name"
        android:localeConfig="@xml/locales_config"
        android:roundIcon="@drawable/ai_photo_change_outfit"
        android:supportsRtl="true"
        android:theme="@style/Theme.StyleSwap">

        <!-- Launcher / first-open orchestrator (Android 12+ system splash) -->
        <activity
            android:name=".firstopen.SplashActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.StyleSwap.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- First-open: language (2 screens) -->
        <activity
            android:name=".firstopen.language.LanguageFO1Activity"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".firstopen.language.LanguageFO2Activity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- First-open: survey (3 steps) -->
        <activity
            android:name=".firstopen.survey.SurveyActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".firstopen.survey.SurveyDupActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".firstopen.survey.Survey3Activity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- First-open: onboarding + permission -->
        <activity
            android:name=".firstopen.onboarding.OnboardingActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".firstopen.PermissionActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- Main app -->
        <activity
            android:name=".ui.main.MainActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.edit.EditActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.settings.SettingsActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.settings.PrivacyActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- Per-app language: persist AppCompatDelegate.setApplicationLocales on API < 33 -->
        <service
            android:name="androidx.appcompat.app.AppLocalesMetadataHolderService"
            android:enabled="false"
            android:exported="false">
            <meta-data
                android:name="autoStoreLocales"
                android:value="true" />
        </service>

    </application>

</manifest>
